{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "[ \"$(git rev-parse --abbrev-ref HEAD 2>/dev/null)\" != \"main\" ] || { echo '{\"decision\":\"block\",\"reason\":\"Cannot edit files on main branch. Create a feature branch first.\"}' && exit 2; }",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/block-destructive.sh\"",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch"
    ],
    "deny": [
      "Edit(.env)",
      "Edit(.env.local)",
      "Edit(.env.production)",
      "Read(.env)",
      "Read(.env.local)",
      "Read(.env.production)"
    ]
  }
}
